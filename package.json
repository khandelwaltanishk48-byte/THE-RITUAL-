{
  "name": "the-ritual",
  "version": "1.0.0",
  "description": "Daily consistency tracker — build your ritual",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.theritual.app",
    "productName": "The Ritual",
    "copyright": "Copyright © 2025",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "hardenedRuntime": false,
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ]
    },
    "dmg": {
      "title": "The Ritual",
      "background": "assets/dmg-bg.png",
      "window": { "width": 540, "height": 380 },
      "contents": [
        { "x": 140, "y": 190, "type": "file" },
        { "x": 400, "y": 190, "type": "link", "path": "/Applications" }
      ]
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "auto-launch": "^5.0.6",
    "electron-store": "^8.1.0"
  }
}
